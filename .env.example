# Copy this to .env only for local testing. In Coolify, define these in the
# resource environment UI.

# Pin a tested Infisical version. Update deliberately after reading the
# Infisical release notes and taking a database backup.
INFISICAL_IMAGE=infisical/infisical:v0.160.5

# Coolify normally generates this from the domain assigned to backend:8080.
# For local compose testing, set it manually.
SERVICE_URL_BACKEND_8080=https://infisical.example.com
SITE_URL=https://infisical.example.com

# Coolify-generated defaults for brand-new instances. Coolify will populate
# these from the compose magic vars; local users can set real generated values.
SERVICE_HEX_32_INFISICALENCRYPTIONKEY=replace-with-coolify-generated-32-char-hex-key
SERVICE_REALBASE64_32_INFISICALAUTHSECRET=replace-with-coolify-generated-base64-auth-secret

# Optional overrides. For migration, copy these from the existing production
# service. Do not restore an existing database with fresh generated values.
ENCRYPTION_KEY=
AUTH_SECRET=

# Coolify can generate these with SERVICE_USER_* / SERVICE_PASSWORD_* magic vars.
SERVICE_USER_POSTGRES=infisical
SERVICE_PASSWORD_POSTGRES=replace-with-generated-or-migration-password
POSTGRES_DB=infisical

NODE_ENV=production
ALLOW_EMPTY_PASSWORD=yes

# Optional SMTP.
SMTP_HOST=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_PORT=
SMTP_FROM_ADDRESS=
SMTP_FROM_NAME=

# Optional GitHub App connection.
INF_APP_CONNECTION_GITHUB_APP_CLIENT_ID=
INF_APP_CONNECTION_GITHUB_APP_CLIENT_SECRET=
INF_APP_CONNECTION_GITHUB_APP_SLUG=
INF_APP_CONNECTION_GITHUB_APP_ID=
# Use one line with literal \n sequences. The compose command converts it back
# to a multiline PEM before starting Infisical.
INF_APP_CONNECTION_GITHUB_APP_PRIVATE_KEY=
